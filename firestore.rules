rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isVerified() && request.auth.token.email == 'nguyenhuynhngochien358lx@gmail.com';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // Poem Validation
    function isValidPoem(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() <= 200
          && data.content is string && data.content.size() > 0 && data.content.size() <= 20000
          && data.date is string && data.date.size() > 0 && data.date.size() <= 100
          && data.createdAt == request.time;
    }

    // Prose Validation
    function isValidProse(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() <= 200
          && data.excerpt is string && data.excerpt.size() > 0 && data.excerpt.size() <= 20000
          && data.date is string && data.date.size() > 0 && data.date.size() <= 100
          && data.createdAt == request.time;
    }

    // Gallery Item Validation
    function isValidGalleryItem(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() <= 200
          && data.desc is string && data.desc.size() > 0 && data.desc.size() <= 20000
          && data.category in ['Phong cảnh', 'Nhân vật']
          && data.seed is string && data.seed.size() > 0
          && data.align in ['left', 'right']
          && (data.get('isUploaded', false) == true || data.get('isUploaded', false) == false)
          && data.createdAt == request.time;
    }

    // Collection Rules
    match /poems/{poemId} {
      allow read: if true;
      allow create: if isAdmin() && isValidPoem(incoming());
      allow update: if isAdmin() && isValidPoem(incoming());
      allow delete: if isAdmin();
    }

    match /prose/{proseId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProse(incoming());
      allow update: if isAdmin() && isValidProse(incoming());
      allow delete: if isAdmin();
    }

    match /gallery/{itemId} {
      allow read: if true;
      allow create: if isAdmin() && isValidGalleryItem(incoming());
      allow update: if isAdmin() && isValidGalleryItem(incoming());
      allow delete: if isAdmin();
    }

    match /config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /stories/{storyId} {
      allow read: if true;
      allow write: if isAdmin();
      
      match /chapters/{chapterId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }
  }
}
